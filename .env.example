# ============================================================
# 股票智能分析平台 · 部署配置模板
# 复制为 .env 并按需修改：cp .env.example .env
# 所有配置均有默认值，不配置也能启动（但推送需至少配一个渠道）
# ============================================================

# ─── Web 服务 ───
# HOST=0.0.0.0
# PORT=8888
# 对外访问地址（推送消息中的报告链接会用它，改成你的服务器 IP 或域名）
PUBLIC_BASE_URL=http://your-server-ip:8888

# ─── 账号与访问控制 ───
# 站点采用邀请制：账号仅能由管理员在「用户管理」页开设，游客只能浏览页面。
# 内置管理员（首次启动自动创建；已存在时不会覆盖界面上改过的密码）
# ⚠️ 公网部署必须修改默认密码：要么此处配置，要么登录后立即在界面修改
# ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
# 登录会话有效期（秒，默认 7 天）；会话签名密钥自动生成并持久化到 data/.session_secret
# SESSION_MAX_AGE=604800
# SESSION_SECRET=

# ─── 定时任务（时间格式 HH:MM，仅交易日执行）───
# 收盘后批量分析启动时间
# AFTER_MARKET_ANALYSIS_TIME=15:10
# 早盘推荐推送时间
# MORNING_PUSH_TIME=08:20
# 每日磁盘清理时间
# CLEANUP_TIME=03:30
# 每日定时分析深度：quick(约7分钟/只) / standard(约25分钟/只) / deep(约50分钟/只)
# DAILY_ANALYSIS_DEPTH=standard

# ─── 并发与分析量 ───
# 同时执行的分析任务数（每任务约占 300-500MB 内存，按服务器内存设置：4G→2，8G→3-4）
# MAX_CONCURRENT_TASKS=2
# 每个大板块每日选股数（6 大板块 × 3 = 每天 18 只）
# STOCKS_PER_SECTOR=3

# ─── 推送渠道 ───
# 启用的渠道，逗号分隔，可多选：serverchan,pushplus,dingtalk,wecom,telegram,email
# 留空则不推送
NOTIFY_CHANNELS=serverchan

# 批量分析完成后是否立即推送（false 则只在早盘定时推送）
# NOTIFY_ON_ANALYSIS_COMPLETE=true

# Server酱 Turbo（微信推送，https://sct.ftqq.com 免费申请 SendKey）
SERVERCHAN_SENDKEY=

# PushPlus（微信推送，https://www.pushplus.plus）
PUSHPLUS_TOKEN=

# 钉钉群机器人（webhook 完整地址；如开启加签需同时填 SECRET）
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 企业微信群机器人（webhook 完整地址）
WECOM_WEBHOOK=

# Telegram Bot（境外服务器推荐）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP 邮件（465=SSL，587=STARTTLS；SMTP_TO 多个收件人用逗号分隔）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=

# ─── 数据保留（天）───
# REPORT_RETENTION_DAYS=7
# CACHE_RETENTION_DAYS=3
# LOG_RETENTION_DAYS=30
# TASK_RETENTION_DAYS=90

# ─── 分析超时（秒，一般无需修改）───
# ANALYSIS_TIMEOUT_QUICK=600
# ANALYSIS_TIMEOUT_STANDARD=1800
# ANALYSIS_TIMEOUT_DEEP=3600
# FETCHER_TIMEOUT=180

# ─── UZI-Skill ───
# skill 模式：builtin（自动 clone 官方仓库到 skills/）/ external（使用已有本地路径）
# SKILL_MODE=builtin
# 自动更新开关与检查间隔（天）：每 N 天 git ls-remote 比对远端，有新 commit 才拉取
# AUTO_UPDATE_SKILL=true
# SKILL_UPDATE_INTERVAL_DAYS=3
# 仓库地址与分支（默认官方仓库，一般无需修改）
# SKILL_REPO_URL=https://github.com/wbh604/UZI-Skill.git
# SKILL_BRANCH=main
# GitHub 镜像代理（大陆服务器直连 GitHub 失败时配置，如 https://gh-proxy.com/）
# GITHUB_PROXY=
# 境外服务器建议配置东财妙想 API Key（大陆服务器不需要）
# MX_APIKEY=

# ─── 容器/面板部署（Pterodactyl 等）───
# Cloudflare Tunnel token（Zero Trust → Tunnels 创建后复制；配置即启用自定义域名 HTTPS）
# CF_TUNNEL_TOKEN=

# ─── LLM API（可选，用于 trap-detector 降级分析；不配置不影响核心功能）───
# 也可以单独放在 .env.llm 中
# LLM_API_BASE=https://your-api-endpoint/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=claude-opus-4-8
# LLM_TIMEOUT=120
