# 敏感配置文件
.env
.env.llm

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 会话签名密钥（运行时自动生成，泄露可伪造登录态）
data/.session_secret

# 调度器补跑状态（运行时生成；入库会把本机"已跑"状态带到新部署导致误判）
data/.scheduler-state.json

# 批量分析批次快照（运行时生成，断点续跑用；同上不入库）
data/.batch-state.json

# 数据库（含 SQLite WAL 模式运行时文件）
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
data/*.db
data/*.sqlite
data/*.sqlite3
!data/.gitkeep

# 日志
logs/*.log
!logs/.gitkeep

# 报告
reports/*.html
!reports/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# 临时文件
.cache/
tmp/
temp/
*.tmp

# Skill 自动更新（持久化克隆仓库与版本记录）
skills/.repo/
skills/.skill-version.json

# Skill 安装副本（启动时由 skill_manager 从上游仓库自动安装/更新，非本仓库源码）
skills/deep-analysis/
skills/lhb-analyzer/
skills/trap-detector/
skills/investor-panel/

# Claude Code 本地工作目录（操作日志与审查报告，不进入公开仓库）
.claude/

# 容器部署运行时产物
.deps-installed
cloudflared
venv/

# 操作系统
.DS_Store
Thumbs.db

# 测试输出
test_*.log
nohup.out
